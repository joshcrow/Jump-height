# ------------------------------------------------------------------- logging
# Every command tees its terminal output AND raw serial traffic (TX/RX,
# timestamped) into data/logs/<time>-<cmd>.log — so when something goes
# wrong, `./tools/jump report` can hand the whole story to a human or an AI
# assistant without the user having to reproduce anything.


class SessionLog:
    def __init__(self):
        self.path: Path | None = None
        self._f = None
        self._t0 = 0.0

    def start(self, cmd: str) -> None:
        logs = DATA_DIR / "logs"
        logs.mkdir(parents=True, exist_ok=True)
        self.path = logs / f"{datetime.now().strftime('%Y%m%d-%H%M%S')}-{cmd}.log"
        self._f = open(self.path, "w")
        self._t0 = time.monotonic()
        self._f.write(f"# jump {cmd} — {datetime.now().isoformat()}\n"
                      f"# argv: {' '.join(sys.argv[1:])}\n"
                      f"# platform: {sys.platform}  python: {sys.version.split()[0]}\n\n")
        sys.stdout = _Tee(sys.stdout, self)
        sys.stderr = _Tee(sys.stderr, self)

    def serial(self, direction: str, text: str) -> None:
        if self._f:
            self._f.write(f"[{time.monotonic() - self._t0:9.3f}] {direction} {text}\n")
            self._f.flush()

    def raw(self, text: str) -> None:
        if self._f:
            self._f.write(text)
            self._f.flush()


class _Tee:
    def __init__(self, orig, log: SessionLog):
        self._orig = orig
        self._log = log

    def write(self, s: str):
        self._orig.write(s)
        self._log.raw(s)
        return len(s)

    def flush(self):
        self._orig.flush()

    def isatty(self):
        return self._orig.isatty()


LOG = SessionLog()

# ---------------------------------------------------------------- serial I/O


class SerialPort:
    """Minimal line-oriented serial port. pyserial if available, else POSIX
    termios. Also works on a pty (the fake device)."""

    def __init__(self, path: str, baud: int = BAUD):
        self.path = path
        self._buf = b""
        self._ser = None
        self._fd = None
        try:
            import serial  # type: ignore

            # Portable path: rely on pyserial's own timeout mechanism only.
            # (No fileno()/select() here — neither works for serial handles
            # on Windows.)
            self._ser = serial.Serial(path, baud, timeout=0.25)
            # Deassert DTR/RTS so ESP32 boards settle into RUN mode.
            try:
                self._ser.dtr = False
                self._ser.rts = False
            except Exception:
                pass
        except ImportError:
            import termios
            import tty

            self._fd = os.open(path, os.O_RDWR | os.O_NOCTTY | os.O_NONBLOCK)
            try:
                tty.setraw(self._fd)
                attrs = termios.tcgetattr(self._fd)
                attrs[4] = attrs[5] = termios.B115200
                termios.tcsetattr(self._fd, termios.TCSANOW, attrs)
            except termios.error:
                pass  # pty: raw/baud not meaningful

    def write_line(self, s: str) -> None:
        LOG.serial("TX", s)
        data = (s + "\n").encode()
        if self._ser is not None:
            self._ser.write(data)
        else:
            os.write(self._fd, data)

    def read_line(self, timeout: float) -> str | None:
        """Next complete line (without newline), or None on timeout."""
        deadline = time.monotonic() + timeout
        while True:
            nl = self._buf.find(b"\n")
            if nl >= 0:
                line = self._buf[:nl].rstrip(b"\r")
                self._buf = self._buf[nl + 1:]
                decoded = line.decode(errors="replace")
                if decoded:
                    LOG.serial("RX", decoded)
                return decoded
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                return None
            wait = min(remaining, 0.25)
            chunk = b""
            if self._ser is not None:
                if self._ser.timeout != wait:
                    self._ser.timeout = wait
                try:
                    chunk = self._ser.read(1)  # blocks up to `wait`
                    if chunk and self._ser.in_waiting:
                        chunk += self._ser.read(self._ser.in_waiting)
                except OSError:
                    chunk = b""
            else:
                r, _, _ = select.select([self._fd], [], [], wait)
                if r:
                    try:
                        chunk = os.read(self._fd, 4096)
                    except (OSError, BlockingIOError):
                        chunk = b""
            if chunk:
                self._buf += chunk

    def close(self) -> None:
        if self._ser is not None:
            self._ser.close()
        elif self._fd is not None:
            os.close(self._fd)


KNOWN_USB_GLOBS = [
    "/dev/ttyUSB*", "/dev/ttyACM*",
    # macOS: always the cu.* device, never tty.* (tty blocks on carrier-detect)
    "/dev/cu.usbserial*", "/dev/cu.wchusbserial*", "/dev/cu.SLAB*",
    "/dev/cu.usbmodem*",
]


def scan_ports() -> list[str]:
    candidates: list[str] = []
    try:
        from serial.tools import list_ports  # type: ignore

        candidates = [p.device for p in list_ports.comports() if p.vid is not None]
        # On macOS pyserial reports both /dev/cu.* and /dev/tty.* — keep cu only.
        candidates = [c for c in candidates if not c.startswith("/dev/tty.")]
    except ImportError:
        for g in KNOWN_USB_GLOBS:
            candidates.extend(glob.glob(g))
    return sorted(set(candidates))


def autodetect_port() -> str:
    candidates = scan_ports()
    if len(candidates) == 1:
        return candidates[0]
    if not candidates:
        raise SystemExit(
            "No USB serial device found. Plug the FireBeetle in (data USB cable, "
            "not charge-only), or pass --port /dev/ttyUSB0")
    raise SystemExit(
        f"Multiple serial devices found: {', '.join(candidates)} — pick one with --port")


def parse_kv(line: str) -> dict:
    """'JUMP n=1 airtime_s=0.62' -> {'_tag': 'JUMP', 'n': '1', 'airtime_s': '0.62'}.
    Bare (non key=value) words land in '_args': 'STATE recording' ->
    {'_tag': 'STATE', '_args': ['recording']}."""
    parts = line.split()
    out: dict = {"_tag": parts[0] if parts else "", "_args": []}
    for p in parts[1:]:
        if "=" in p:
            k, v = p.split("=", 1)
            out[k] = v
        else:
            out["_args"].append(p)
    return out


# ------------------------------------------------------------- device session


class Device:
    """A connected (real or fake) device speaking the firmware protocol."""

    def __init__(self, port: str):
        self.sp = SerialPort(port)
        self.boot_lines: list[str] = []

    def drain_boot(self, timeout: float = 5.0) -> None:
        """Board resets when the port opens; swallow the boot banner/POST."""
        deadline = time.monotonic() + timeout
        saw_any = False
        while time.monotonic() < deadline:
            line = self.sp.read_line(0.6)
            if line is None:
                if saw_any:
                    break  # went quiet after output: boot finished
                continue
            saw_any = True
            self.boot_lines.append(line)
            if line.strip() == "READY":
                break

    def command(self, cmd: str, timeout: float = 20.0) -> list[str]:
        """Send a command, return all lines up to its OK/ERR terminator.

        `timeout` is an INACTIVITY timeout: it resets every time a line
        arrives, so a long-but-flowing transfer (e.g. a full `dump` at
        115200 baud) never trips it, while a genuinely stuck device does.
        """
        self.sp.write_line(cmd)
        lines: list[str] = []
        while True:
            line = self.sp.read_line(timeout)
            if line is None:
                raise TimeoutError(
                    f"device went silent during '{cmd}' — is the right firmware flashed?")
            if line.strip() == f"OK {cmd.split()[0]}":
                return lines
            if line.startswith("ERR"):
                lines.append(line)
                return lines
            lines.append(line)

    def wait_for(self, tag: str, timeout: float, echo_chatter: bool = True,
                 value: str | None = None) -> dict | None:
        """Wait for the next machine line with the given tag (e.g. 'JUMP').

        With `value`, only a line whose first bare word matches counts —
        e.g. wait_for('STATE', 30, value='recording') will not be satisfied
        by 'STATE idle'.
        """
        deadline = time.monotonic() + timeout
        while time.monotonic() < deadline:
            line = self.sp.read_line(deadline - time.monotonic())
            if line is None:
                return None
            if line.startswith(tag + " ") or line.strip() == tag:
                kv = parse_kv(line)
                if value is None or (kv["_args"] and kv["_args"][0] == value):
                    return kv
                continue  # right tag, wrong value (e.g. STATE idle): keep waiting
            if echo_chatter and line.startswith("#"):
                print(f"    {line}")
        return None

    def close(self) -> None:
        self.sp.close()


def spawn_fake(scenario: str, fast: bool, extra: list[str] | None = None):
    cmd = [sys.executable, str(REPO / "tools" / "fake_device.py"),
           "--scenario", scenario]
    if fast:
        cmd.append("--fast")
    cmd += extra or []
    env = dict(os.environ)
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, text=True, env=env)
    first = proc.stdout.readline().strip()
    if not first.startswith("PTY "):
        proc.terminate()
        raise SystemExit(f"fake device failed to start: {first!r}")
    return proc, first.split(None, 1)[1]


def open_device(args, fake_scenario: str = "ok", fake_extra: list[str] | None = None):
    """Returns (Device, fake_proc_or_None)."""
    if getattr(args, "fake", False):
        proc, port = spawn_fake(fake_scenario, getattr(args, "fast", False), fake_extra)
        dev = Device(port)
        dev.drain_boot(timeout=3.0)
        return dev, proc
    port = args.port or autodetect_port()
    print(f"Connecting to {port} (the board resets when the port opens — normal)...")
    dev = Device(port)
    dev.drain_boot()
    return dev, None


# ----------------------------------------------------------------- self-test

MARKS = {"PASS": "✅", "WARN": "⚠️ ", "FAIL": "❌", "SKIP": "—"}


def render_selftest(lines: list[str]) -> bool:
    """Pretty-print SELFTEST lines + hints. Returns True if result=PASS."""
    ok = False
    for line in lines:
        if line.startswith("SELFTEST END"):
            ok = "result=PASS" in line
        elif line.startswith("SELFTEST BEGIN"):
            continue
        elif line.startswith("SELFTEST "):
            _, name, status, *rest = line.split()
            detail = rest[0].replace("detail=", "") if rest else ""
            print(f"  {MARKS.get(status, '?')} {name:<8} {detail}")
        elif line.startswith("# hint:"):
            print(f"       {line.replace('# hint:', 'hint:')}")
    return ok


def check_device_params(dev: Device) -> bool:
    """Compare the flashed firmware's params against local config/params.json."""
    try:
        lines = dev.command("info", timeout=8)
    except TimeoutError:
        print("  (couldn't read device info — old firmware? run ./tools/jump flash)")
        return False
    from detector import load_params

    local = load_params(CONFIG_PATH)
    device_kv = {}
    for line in lines:
        if line.startswith("PARAMS "):
            device_kv = {k: v for k, v in parse_kv(line).items() if k != "_tag"}
    if not device_kv:
        print("  (device didn't report its params — old firmware? run ./tools/jump flash)")
        return False
    mismatches = []
    for key, dev_val in device_kv.items():
        local_val = getattr(local, key, None)
        if local_val is None:
            continue
        try:
            if not math.isclose(float(dev_val), float(local_val),
                                rel_tol=1e-4, abs_tol=1e-6):
                mismatches.append(f"{key}: device={dev_val} local={local_val:g}")
        except ValueError:
            pass
    if mismatches:
        print("  ⚠️  device settings differ from config/params.json — run ./tools/jump flash:")
        for m in mismatches:
            print(f"       {m}")
        return False
    print("  ✅ device settings match config/params.json")
    return True


def cmd_selftest(args) -> int:
    dev, proc = open_device(args, "badwiring" if getattr(args, "fake_fail", False) else "ok")
    try:
        lines = dev.command("selftest", timeout=15)
        print("Self-test:")
        ok = render_selftest(lines)
        params_ok = check_device_params(dev)
        if ok:
            print("\nRESULT: PASS ✅ — hardware is good."
                  + ("" if params_ok else " (but re-flash to sync settings)"))
            return 0
        print("\nRESULT: FAIL ❌ — follow the hints above, fix the wiring, and run "
              "./tools/jump selftest again. No re-flash needed.")
        return 1
    finally:
        dev.close()
        if proc:
            proc.terminate()


# ------------------------------------------------------------------ desktest


def _pause(args, dev: Device, msg: str) -> None:
    if getattr(args, "fake", False):
        print(f">> {msg}")
        dev.sp.write_line("_sim next")  # tell the fake "the human just did this"
    elif not sys.stdin.isatty():
        print(f">> {msg}")
    else:
        input(f">> {msg}  [Enter when ready] ")


def cmd_desktest(args) -> int:
    dev, proc = open_device(args, "desktest")
    try:
        print("=== Desk test: proves the whole assembly works ===\n")
        print("[1/3] Self-test...")
        ok = render_selftest(dev.command("selftest", timeout=15))
        if not ok:
            print("\nFix the wiring per the hints above, then re-run. Stopping here.")
            return 1

        print("\n[2/3] Motion gate...")
        _pause(args, dev, "Pick the device up and give it a shake.")
        if dev.wait_for("STATE", timeout=30, value="recording") is None:
            print("❌ Never saw motion. Is it wired and self-testing OK? Try again.")
            return 1
        print("  ✅ motion detected — recording")

        print("\n[3/3] Jump detection: 3 gentle tosses.")
        print("  Toss the device ~30–50 cm straight up over a cushion or bed and")
        print("  let it land. (Drops under ~35 cm are ignored by design.)\n")
        heights = []
        for i in range(1, 4):
            _pause(args, dev, f"Toss {i} of 3.")
            ev = dev.wait_for("JUMP", timeout=60)
            if ev is None:
                print(f"  ❌ toss {i}: nothing detected in 60s. Toss a little higher —")
                print("     airtime must exceed min_airtime_s "
                      "(see config/params.json).")
                return 1
            raw = float(ev.get("airtime_raw_s", 0))
            h = float(ev.get("height_m", 0))
            plaus = "✅" if 0.10 <= raw <= 1.2 else "⚠️ implausible for a hand toss"
            print(f"  {plaus} toss {i}: airtime {raw:.2f}s → height {h:.2f} m")
            heights.append(h)

        stats_lines = dev.command("stats", timeout=8)
        n = 0
        for line in stats_lines:
            if line.startswith("STATS"):
                n = int(parse_kv(line).get("session_jumps", "0"))
        if n >= 3 and len(heights) == 3:
            print(f"\nRESULT: PASS ✅ — assembly verified ({n} jumps this session).")
            print("Next: calibration with ./tools/jump drop")
            return 0
        print(f"\nRESULT: CHECK ⚠️ — expected 3 recorded jumps, device says {n}.")
        return 1
    finally:
        dev.close()
        if proc:
            proc.terminate()


# ---------------------------------------------------------------------- drop


def cmd_drop(args) -> int:
    from detector import load_params

    p = load_params(CONFIG_PATH)
    h = args.height_cm / 100.0
    expected = math.sqrt(2.0 * h / p.g)
    min_h_cm = 100.0 * p.g * p.min_airtime_s ** 2 / 2.0
    if args.height_cm < min_h_cm + 10:
        print(f"Drop height {args.height_cm:.0f} cm is too low — anything under "
              f"~{min_h_cm:.0f} cm is ignored by design (min_airtime_s). "
              f"Use ≥ {min_h_cm + 15:.0f} cm (a table or head height works).")
        return 1

    dev, proc = open_device(
        args, "drop",
        ["--height-cm", str(args.height_cm), "--drops", str(args.drops)])
    try:
        print("=== Drop calibration ===")
        print(f"Physics: a drop from {args.height_cm:.0f} cm free-falls for exactly "
              f"{expected:.3f}s.\nWe compare what the device measures against that "
              "to find its timing bias.\n")
        print("Setup: hold the device so its BOTTOM is exactly at your measured")
        print(f"height ({args.height_cm:.0f} cm above a cushion/pillow), then let go —")
        print("don't throw it. Keep still for a second before each drop.\n")

        _pause(args, dev, "Shake the device once to wake it.")
        dev.wait_for("STATE", timeout=30, value="recording")

        raws: list[float] = []
        for i in range(1, args.drops + 1):
            _pause(args, dev, f"Drop {i} of {args.drops}.")
            ev = dev.wait_for("JUMP", timeout=90)
            if ev is None:
                print(f"  ⚠️ drop {i}: not detected (too low? bounced oddly?) — skipping")
                continue
            raw = float(ev.get("airtime_raw_s", 0))
            raws.append(raw)
            print(f"  drop {i}: measured {raw:.3f}s (true {expected:.3f}s, "
                  f"error {raw - expected:+.3f}s)")

        if len(raws) < 3:
            print(f"\nOnly {len(raws)} good drops — need at least 3. Re-run, "
                  "dropping from a bit higher.")
            return 1

        offset = -statistics.median(r - expected for r in raws)
        spread = statistics.pstdev(raws)
        print(f"\nMeasured timing bias: {-offset * 1000:+.0f} ms "
              f"(spread ±{spread * 1000:.0f} ms over {len(raws)} drops)")
        print(f"Recommended airtime_offset_s = {offset:+.4f}")
        # Honest residual: per-drop height error remaining AFTER the correction
        # (median-centering forces the median residual to zero, so report the
        # per-drop scatter instead; drop height obeys h = g*t^2/2).
        errs_cm = [abs(p.g * ((r + offset) ** 2 - expected ** 2) / 2.0) * 100
                   for r in raws]
        print(f"Typical per-drop scatter after correction: "
              f"{statistics.mean(errs_cm):.1f} cm of drop height.")

        if spread > 0.03:
            print("⚠️  spread is high — results may be sloppy. Consider re-running "
                  "with more careful, stiller drops.")

        write = args.yes
        if not write and sys.stdin.isatty() and not getattr(args, "fake", False):
            write = input("\nWrite this into config/params.json? [y/N] ").strip().lower() == "y"
        if write:
            with open(CONFIG_PATH) as f:
                cfg = json.load(f)
            cfg["detector"]["airtime_offset_s"] = round(offset, 4)
            with open(CONFIG_PATH, "w") as f:
                json.dump(cfg, f, indent=2)
                f.write("\n")
            print(f"✅ saved to {CONFIG_PATH}")
            print("Now run  ./tools/jump flash  to bake it into the device.")
        else:
            print("(not saved — re-run with --yes to save automatically)")
        return 0
    finally:
        dev.close()
        if proc:
            proc.terminate()


# ---------------------------------------------------------------------- sync


def split_segments(rows: list[tuple[float, float]]) -> list[list[tuple[float, float]]]:
    """Split a trace wherever time goes backwards (device rebooted)."""
    segs: list[list[tuple[float, float]]] = []
    cur: list[tuple[float, float]] = []
    last_t = None
    for t, m in rows:
        if last_t is not None and t < last_t:
            if cur:
                segs.append(cur)
            cur = []
        cur.append((t, m))
        last_t = t
    if cur:
        segs.append(cur)
    return segs


def parse_file_sections(lines: list[str]) -> dict:
    files: dict[str, list[str]] = {}
    current = None
    for line in lines:
        if line.startswith("FILE ") and line.endswith(" BEGIN"):
            current = line.split()[1]
            files[current] = []
        elif line.startswith("FILE ") and line.endswith(" END"):
            current = None
        elif current is not None:
            files[current].append(line)
    return files


def cmd_sync(args) -> int:
    from detector import Detector, load_params

    dev, proc = open_device(args, "session")
    try:
        print("Downloading session data...")
        check_device_params(dev)
        lines = dev.command("dump", timeout=120)
        files = parse_file_sections(lines)
        jumps_csv = "\n".join(files.get("jumps.csv", []))
        trace_csv = "\n".join(files.get("trace.csv", []))

        out_root = Path(args.out) if args.out else DATA_DIR / "sessions"
        sess = out_root / datetime.now().strftime("%Y%m%d-%H%M%S")
        sess.mkdir(parents=True, exist_ok=True)
        (sess / "jumps.csv").write_text(jumps_csv + "\n")
        (sess / "trace.csv").write_text(trace_csv + "\n")

        # Device's own jump list
        dev_jumps: list[dict] = []
        for row in files.get("jumps.csv", [])[1:]:
            cells = row.split(",")
            if len(cells) >= 5:
                try:
                    dev_jumps.append({
                        "takeoff": float(cells[1]), "raw": float(cells[2]),
                        "airtime": float(cells[3]), "height": float(cells[4])})
                except ValueError:
                    pass

        # Offline re-detection over the trace (catches jumps the live pass missed)
        rows: list[tuple[float, float]] = []
        for row in files.get("trace.csv", [])[1:]:
            cells = row.split(",")
            if len(cells) >= 2:
                try:
                    rows.append((float(cells[0]), float(cells[1])))
                except ValueError:
                    pass
        params = load_params(CONFIG_PATH)
        offline: list = []
        for seg in split_segments(rows):
            det = Detector(params)
            for t, m in seg:
                ev = det.update(t, m)
                if ev:
                    offline.append(ev)

        # Cross-check: match by airtime (times reset per boot, so counts +
        # airtimes are the robust comparison)
        dev_raws = sorted(j["raw"] for j in dev_jumps)
        off_raws = sorted(e.airtime_raw_s for e in offline)
        agree = len(dev_raws) == len(off_raws) and all(
            abs(a - b) <= 0.05 for a, b in zip(dev_raws, off_raws))

        best = max((j["height"] for j in dev_jumps), default=0.0)
        best_off = max((e.height_m for e in offline), default=0.0)

        report = [
            f"# Session report — {sess.name}", "",
            f"**Device:** {len(dev_jumps)} jumps, best {best:.2f} m "
            f"({best * 3.28084:.1f} ft)",
            f"**Offline re-analysis:** {len(offline)} jumps, best {best_off:.2f} m", "",
            "Agreement: " + ("✅ live and offline detection agree"
                             if agree else
                             "⚠️ live vs offline differ — see tables; consider tuning "
                             "config/params.json and re-running "
                             f"`./tools/jump replay --csv {sess / 'trace.csv'}`"), "",
            "| # | airtime (s) | height (m) | height (ft) |",
            "|---|-------------|------------|-------------|",
        ]
        for i, j in enumerate(dev_jumps, 1):
            report.append(f"| {i} | {j['airtime']:.2f} | {j['height']:.2f} | "
                          f"{j['height'] * 3.28084:.1f} |")
        report += [
            "",
            f"Params: `{params}`", "",
            "_Note: the device accumulates jumps until `clear`; timestamps reset "
            "each power-up. Sync + clear after every session to keep reports "
            "one-session-per-file._",
        ]
        (sess / "report.md").write_text("\n".join(report) + "\n")

        print(f"\n=== {len(dev_jumps)} jumps — best {best:.2f} m "
              f"({best * 3.28084:.1f} ft) ===")
        for i, j in enumerate(dev_jumps, 1):
            print(f"  #{i}: airtime {j['airtime']:.2f}s → {j['height']:.2f} m")
        if not agree:
            print("⚠️  offline re-analysis differs from the live detection — "
                  "see the report.")
        print(f"\nSaved: {sess}/report.md (+ raw CSVs for re-tuning)")

        do_clear = args.clear
        if not do_clear and sys.stdin.isatty() and not getattr(args, "fake", False):
            do_clear = input(
                "Clear the device for the next session? [y/N] ").strip().lower() == "y"
        if do_clear:
            dev.command("clear", timeout=10)
            print("✅ device cleared")
        return 0
    finally:
        dev.close()
        if proc:
            proc.terminate()


# ------------------------------------------------------------------- simtest


def _run(cmd: list[str], **kw) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, cwd=str(REPO), capture_output=True, text=True, **kw)


def cmd_simtest(args) -> int:
    print("=== Software test suite (no hardware needed) ===\n")
    results: list[tuple[str, bool, str]] = []

    # 1. Synthetic detector tests across noise seeds
    ok = True
    for seed in range(5):
        r = _run([sys.executable, "sim/run.py", "--seed", str(seed)])
        if "RESULT: PASS" not in r.stdout:
            ok = False
    results.append(("detector vs synthetic ground truth (5 seeds)", ok, ""))

    # 2. Generated params header is in sync with config/params.json
    r = _run([sys.executable, "tools/gen_params.py", "--check"])
    results.append(("params.gen.h in sync with config/params.json", r.returncode == 0,
                    "" if r.returncode == 0 else "run ./tools/jump gen"))

    # 3. C++ (firmware) vs Python (sim) detector parity
    gxx = shutil.which("g++") or shutil.which("c++")
    if gxx:
        import tempfile

        with tempfile.TemporaryDirectory() as td:
            binp = os.path.join(td, "host_test")
            r = _run([gxx, "-std=c++14", "-Wall", "-Wextra", "-I", "firmware/include",
                      "firmware/test/host_test.cpp", "-o", binp])
            if r.returncode != 0:
                results.append(("C++ firmware detector compiles", False, r.stderr[:400]))
            else:
                results.append(("C++ firmware detector compiles", True, ""))
                with open(REPO / "data" / "example_session.csv") as f:
                    rc = subprocess.run([binp], stdin=f, capture_output=True, text=True)
                rp = _run([sys.executable, "sim/golden.py", "data/example_session.csv"])

                def nums(out):
                    return [[float(x.split("=")[1]) for x in ln.split()[1:]]
                            for ln in out.strip().splitlines() if ln.startswith("JUMP")]

                a, b = nums(rc.stdout), nums(rp.stdout)
                parity = (len(a) == len(b) and len(a) > 0 and all(
                    abs(x - y) <= 0.002 for ra, rb in zip(a, b) for x, y in zip(ra, rb)))
                results.append(("C++ and Python detectors agree exactly", parity,
                                f"C++ {len(a)} jumps vs Python {len(b)}"))
    else:
        results.append(("C++ parity check", True, "skipped: no g++ on this machine"))

    # 4. CLI integration tests against the fake device.
    # (JH_SKIP_CLI_TESTS guards recursion: the wizard's software check runs
    # simtest, and these tests themselves run the wizard.)
    if os.environ.get("JH_SKIP_CLI_TESTS"):
        results.append(("CLI + fake-device integration tests", True,
                        "skipped inside wizard"))
    else:
        r = _run([sys.executable, "-m", "unittest", "discover", "-s", "tools/tests"])
        results.append(("CLI + fake-device integration tests", r.returncode == 0,
                        (r.stderr or r.stdout)[-600:] if r.returncode != 0 else ""))

    print()
    all_ok = True
    for name, ok, note in results:
        mark = "✅" if ok else "❌"
        print(f"  {mark} {name}" + (f"  ({note})" if note and not ok else
                                    f"  ({note})" if note else ""))
        all_ok &= ok
    print(f"\nRESULT: {'PASS ✅ — software is good' if all_ok else 'FAIL ❌'}")
    return 0 if all_ok else 1


