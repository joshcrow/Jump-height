def main() -> int:
    ap = argparse.ArgumentParser(
        prog="jump", description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    def add(name, fn, **kw):
        p = sub.add_parser(name, **kw)
        p.set_defaults(fn=fn)
        p.add_argument("--port", help="serial port (default: autodetect)")
        return p

    p = add("wizard", cmd_wizard,
            help="guided end-to-end setup: plug in and follow along (resumable)")
    p.add_argument("--restart", action="store_true", help="forget progress, start over")
    p.add_argument("--yes", action="store_true", help="assume yes at every prompt")
    p.add_argument("--fake", action="store_true", help="rehearse with a simulated device")
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    p = add("report", cmd_report, help="write a diagnostic bundle to send for help")
    p.add_argument("--fake", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    add("setup", cmd_setup, help="one-time toolchain install")
    add("gen", cmd_gen, help="regenerate firmware params header from config")
    add("simtest", cmd_simtest, help="full software test suite, no hardware")

    p = add("flash", cmd_flash, help="build + upload firmware, then self-test")

    p = add("selftest", cmd_selftest, help="check wiring/sensor/storage")
    p.add_argument("--fake", action="store_true", help="use a simulated device")
    p.add_argument("--fake-fail", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    p = add("desktest", cmd_desktest, help="guided assembly check (3 tosses)")
    p.add_argument("--fake", action="store_true", help="rehearse with a simulated device")
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    p = add("drop", cmd_drop, help="calibrate timing from measured drops")
    p.add_argument("--height-cm", type=float, default=100.0,
                   help="measured drop height in cm (default 100)")
    p.add_argument("--drops", type=int, default=5, help="number of drops (default 5)")
    p.add_argument("--yes", action="store_true", help="save result without asking")
    p.add_argument("--fake", action="store_true", help="rehearse with a simulated device")
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    p = add("sync", cmd_sync, help="download session, analyze, write report")
    p.add_argument("--clear", action="store_true", help="clear device after download")
    p.add_argument("--out", help=argparse.SUPPRESS)  # session dir root (tests)
    p.add_argument("--fake", action="store_true", help="rehearse with a simulated device")
    p.add_argument("--fast", action="store_true", help=argparse.SUPPRESS)

    add("monitor", cmd_monitor, help="raw serial console")

    p = add("replay", cmd_replay, help="re-run detector over a capture CSV")
    p.add_argument("--csv", required=True)
    p.add_argument("--plot", action="store_true")

    # web serves over HTTP, so its --port is the HTTP port — not the serial
    # --port that add() attaches to every other command. Register it directly.
    p = sub.add_parser("web", help="serve the browser app locally (localhost)")
    p.set_defaults(fn=cmd_web)
    p.add_argument("--port", type=int, default=8765, help="HTTP port (default 8765)")

    args = ap.parse_args()
    try:
        LOG.start(args.cmd)
    except OSError:
        pass  # logging is best-effort; never block the actual work
    try:
        rc = args.fn(args)
        if LOG.path and args.cmd in ("flash", "selftest", "desktest", "drop",
                                     "sync", "monitor"):
            print(f"(session log: {LOG.path})")
        return rc
    except TimeoutError as e:
        print(f"❌ {e}")
        if LOG.path:
            print(f"(session log for troubleshooting: {LOG.path} — "
                  "or run ./tools/jump report)")
        return 1
    except KeyboardInterrupt:
        print("\ninterrupted")
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
