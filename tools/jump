def find_pio() -> str | None:
    for cand in ("pio", "platformio"):
        p = shutil.which(cand)
        if p:
            return p
    for p in (Path.home() / ".local" / "bin" / "pio",
              Path.home() / ".platformio" / "penv" / "bin" / "pio"):
        if p.exists():
            return str(p)
    return None


def cmd_setup(args) -> int:
    print("=== One-time toolchain setup ===\n")
    ok = True
    print(f"✅ Python {sys.version.split()[0]}")

    if find_pio():
        print("✅ PlatformIO already installed")
    else:
        print("Installing PlatformIO (builds + uploads the firmware)...")
        r = subprocess.run([sys.executable, "-m", "pip", "install", "--user",
                            "platformio"])
        if r.returncode == 0 and find_pio():
            print("✅ PlatformIO installed")
        else:
            print("❌ PlatformIO install failed — see https://platformio.org/install")
            ok = False

    try:
        import serial  # type: ignore  # noqa: F401
        print("✅ pyserial available")
    except ImportError:
        r = subprocess.run([sys.executable, "-m", "pip", "install", "--user",
                            "pyserial"])
        if r.returncode == 0:
            print("✅ pyserial installed")
        elif os.name == "posix":
            print("⚠️  pyserial install failed — built-in fallback will be used")
        else:
            print("❌ pyserial install failed (required on Windows)")
            ok = False

    if shutil.which("g++") or shutil.which("c++"):
        print("✅ C++ compiler (enables the firmware parity test)")
    else:
        print("⚠️  no C++ compiler — simtest will skip the parity check (fine)")

    local_bin = str(Path.home() / ".local" / "bin")
    if local_bin not in os.environ.get("PATH", ""):
        print(f"\nNote: if 'pio' isn't found later, add {local_bin} to your PATH.")
    print("\nNext: ./tools/jump simtest   (should PASS with no hardware)")
    return 0 if ok else 1


def cmd_gen(args) -> int:
    import gen_params

    gen_params.HEADER_PATH.write_text(
        gen_params.render_header(gen_params.load_config(CONFIG_PATH)))
    print(f"wrote {gen_params.HEADER_PATH}")
    return 0


def cmd_flash(args) -> int:
    cmd_gen(args)
    pio = find_pio()
    if not pio:
        print("PlatformIO not found — run ./tools/jump setup first.")
        return 1
    cmd = [pio, "run", "-d", str(REPO / "firmware"), "-t", "upload"]
    if args.port:
        cmd += ["--upload-port", args.port]
    print("Building + uploading firmware (first build downloads the toolchain — "
          "takes a few minutes once)...")
    # Stream pio's output line by line through our stdout so it lands in the
    # session log too (a plain subprocess would bypass the log tee).
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            text=True)
    for line in proc.stdout:
        print(line, end="")
    proc.wait()
    if proc.returncode != 0:
        print("\n❌ upload failed. Board plugged in? Data-capable USB cable? "
              "Try --port <port>, and `./tools/jump report` to collect diagnostics.")
        return 1
    print("\n✅ flashed. Running self-test...")
    time.sleep(1.5)
    return cmd_selftest(args)


def cmd_monitor(args) -> int:
    port = args.port or autodetect_port()
    sp = SerialPort(port)
    interactive = os.name == "posix"  # select() on stdin is POSIX-only
    print(f"--- monitor {port} (Ctrl-C to exit"
          + ("; type a command + Enter) ---" if interactive else "; read-only) ---"))
    try:
        while True:
            line = sp.read_line(0.1)
            if line is not None:
                print(line)
            if not interactive:
                continue
            r, _, _ = select.select([sys.stdin], [], [], 0)
            if r:
                cmdline = sys.stdin.readline()
                if cmdline:
                    sp.write_line(cmdline.strip())
    except KeyboardInterrupt:
        print("\n--- bye ---")
        return 0
    finally:
        sp.close()


def cmd_replay(args) -> int:
    # Absolutize before changing cwd, so a path relative to where the user
    # ran the command still resolves.
    cmd = [sys.executable, "sim/run.py", "--csv", os.path.abspath(args.csv)]
    if args.plot:
        cmd.append("--plot")
    return subprocess.run(cmd, cwd=str(REPO)).returncode


# ----------------------------------------------------------------------- web
# Serve web/ (the browser app) on localhost. WHY a local server and not just
# opening the file: browsers only expose Web Bluetooth / Web Serial to a
# "secure context", and localhost qualifies while a file:// path does not — so
# this is the way to run the app during development.


def stage_firmware(web_dir: Path) -> None:
    """Copy a fresh firmware build into web/firmware/ for the browser flasher.

    ESP Web Tools (the app's Install tab) flashes three files: the bootloader,
    the partition table, and the app image — all from the PlatformIO build dir.
    (No boot_app0.bin: that's the OTA-slot selector, and our partition map is
    factory-only with no OTA, so flashing it would just scribble on the unused
    phy_init region and diverge from what a USB flash writes.) If the build
    hasn't happened yet we just say so — the app already degrades to a friendly
    'not built yet' note when the binaries aren't served.
    """
    build = REPO / "firmware" / ".pio" / "build" / "firebeetle32"
    wanted = ["bootloader.bin", "partitions.bin", "firmware.bin"]
    if not all((build / f).exists() for f in wanted):
        print("Firmware binaries aren't built yet — the app's Install tab will "
              "say so.\n(Run  ./tools/jump flash  to build them.)\n")
        return
    out = web_dir / "firmware"
    out.mkdir(parents=True, exist_ok=True)
    for f in wanted:
        shutil.copy2(build / f, out / f)
    # Drop a stale boot_app0 from an older staging so the served set matches
    # the manifest exactly.
    (out / "boot_app0.bin").unlink(missing_ok=True)
    print(f"Staged firmware into {out} for the in-browser flasher: "
          + ", ".join(wanted) + "\n")


def cmd_web(args) -> int:
    from functools import partial
    from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer

    web_dir = REPO / "web"
    if not (web_dir / "index.html").exists():
        print(f"❌ no browser app found at {web_dir} — is the repo intact?")
        return 1

    stage_firmware(web_dir)

    port = args.port
    url = f"http://localhost:{port}/"
    handler = partial(SimpleHTTPRequestHandler, directory=str(web_dir))
    try:
        httpd = ThreadingHTTPServer(("127.0.0.1", port), handler)
    except OSError as e:
        print(f"❌ couldn't serve on port {port}: {e}")
        print(f"   Port already in use? Try  ./tools/jump web --port {port + 1}")
        return 1

    print(f"Serving the Jump Height app at  {url}")
    print("  • localhost is a secure context, so Web Bluetooth and Web Serial")
    print("    both work here (they don't from a file:// path).")
    print("  • Open it in Chrome or Edge on a desktop — those are the browsers")
    print("    that support Web Bluetooth + Web Serial.")
    print("  • Ctrl-C to stop.\n")

    # macOS nicety: pop the default browser open. Best-effort — a Linux or
    # headless box simply skips it.
    if sys.platform == "darwin":
        try:
            subprocess.Popen(["open", url])
        except Exception:
            pass

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\n--- stopped ---")
    finally:
        httpd.server_close()
    return 0


# -------------------------------------------------------------------- wizard

STATE_PATH_NAME = "wizard_state.json"
WIZARD_STEPS = ["software", "connect", "flash", "desktest", "drop"]
STEP_TITLES = {
    "software": "Software check (no hardware needed)",
    "connect":  "Find your board",
    "flash":    "Install the firmware + wiring self-test",
    "desktest": "Prove the assembly (3 tosses)",
    "drop":     "Calibrate (measured drops)",
}


def _state_path() -> Path:
    return DATA_DIR / STATE_PATH_NAME


def load_wizard_state() -> dict:
    try:
        return json.loads(_state_path().read_text())
    except (OSError, ValueError):
        return {}


def save_wizard_state(st: dict) -> None:
    _state_path().parent.mkdir(parents=True, exist_ok=True)
    _state_path().write_text(json.dumps(st, indent=2) + "\n")


def _confirm(args, msg: str, default: bool = True) -> bool:
    if getattr(args, "yes", False) or getattr(args, "fake", False) or not sys.stdin.isatty():
        print(f">> {msg}  [auto-{'yes' if default else 'no'}]")
        return default
    d = "Y/n" if default else "y/N"
    ans = input(f">> {msg}  [{d}] ").strip().lower()
    if not ans:
        return default
    return ans.startswith("y")


def _ns(args, **kw) -> argparse.Namespace:
    """Build a Namespace for calling another cmd_* from the wizard."""
    base = dict(port=getattr(args, "port", None), fake=getattr(args, "fake", False),
                fast=getattr(args, "fast", False), fake_fail=False, yes=True)
    base.update(kw)
    return argparse.Namespace(**base)


def wizard_connect(args, st: dict) -> str | None:
    """Find the board's serial port, by watching for it to appear."""
    before = set(scan_ports())
    if len(before) == 1 and _confirm(args, f"Found one device at {next(iter(before))} — use it?"):
        return next(iter(before))
    if before:
        print(f"  (currently visible: {', '.join(sorted(before))})")
        print("  To be sure we pick the right one, unplug the board now.")
        if sys.stdin.isatty():
            input(">> Unplugged (or it never was plugged in)?  [Enter] ")
        before = set(scan_ports())
    print("\n  Now plug the FireBeetle into this computer with a USB DATA cable.")
    print("  (Charge-only cables are the #1 gotcha — if in doubt, try another cable.)")
    deadline = time.monotonic() + 60
    while time.monotonic() < deadline:
        new = set(scan_ports()) - before
        if new:
            port = sorted(new)[0]
            print(f"  ✅ found it: {port}")
            return port
        time.sleep(0.5)
    print("""  ❌ No new serial device appeared in 60s. In order of likelihood:
     1. The USB cable is charge-only — swap cables (most common by far).
     2. Try a different USB port / skip any hub.
     3. macOS: open  > About This Mac > System Report > USB — if the board
        shows up there but no /dev/cu.* port exists, the USB-serial chip
        driver is missing (search: "CH34x macOS driver" or "CP210x driver").
     4. Run ./tools/jump report and send the file to Claude.""")
    return None


def cmd_wizard(args) -> int:
    st = {} if args.restart else load_wizard_state()
    done: dict = st.setdefault("completed", {})

    print("=" * 62)
    print("  JUMP HEIGHT — guided setup")
    print("  Plug in, follow along; every screen ends in ✅ or a fix.")
    print("  Safe to quit anytime (Ctrl-C) — it resumes where you left off.")
    print("=" * 62)
    if done:
        print("\nWelcome back. Already done: "
              + ", ".join(STEP_TITLES[s] for s in WIZARD_STEPS if s in done))
        print("(start over with: ./tools/jump wizard --restart)")

    def begin(step: str) -> bool:
        if step in done:
            return False
        n = WIZARD_STEPS.index(step) + 1
        print(f"\n───── Step {n}/{len(WIZARD_STEPS)}: {STEP_TITLES[step]} ─────")
        return True

    def finish(step: str) -> None:
        done[step] = datetime.now().isoformat(timespec="seconds")
        save_wizard_state(st)

    def bail(msg: str) -> int:
        print(f"\n⏸  {msg}")
        print("   Fix that, then run  ./tools/jump wizard  again — it resumes here.")
        print("   Stuck? Run  ./tools/jump report  and send the file to Claude.")
        return 1

    # 1. software
    if begin("software"):
        os.environ["JH_SKIP_CLI_TESTS"] = "1"  # the CLI test suite runs the wizard
        try:
            if find_pio() is None:
                print("  PlatformIO not found — running the one-time setup first.\n")
                cmd_setup(args)
                if find_pio() is None:
                    return bail("PlatformIO didn't install — see https://platformio.org/install")
            if cmd_simtest(args) != 0:
                return bail("The software self-test failed.")
        finally:
            os.environ.pop("JH_SKIP_CLI_TESTS", None)
        finish("software")

    # 2. connect
    if begin("connect"):
        if args.fake:
            print("  (simulated device mode — skipping the real port hunt)")
        else:
            port = args.port or wizard_connect(args, st)
            if port is None:
                return bail("Couldn't find the board.")
            st["port"] = port
        finish("connect")
    args.port = args.port or st.get("port")

    # 3. flash (includes the automatic wiring self-test)
    if begin("flash"):
        if args.fake:
            print("  (simulated device — skipping the real flash; running self-test)")
            if cmd_selftest(_ns(args)) != 0:
                return bail("Self-test failed.")
        else:
            print("  Make sure the 4 sensor wires are connected (BUILD.md wiring table):")
            print("    VCC→3V3   GND→GND   SDA→SDA(IO21)   SCL→SCL(IO22)")
            if not _confirm(args, "Wired up and plugged in — flash the firmware now?"):
                return bail("Flash skipped.")
            if cmd_flash(_ns(args)) != 0:
                return bail("Flashing or the wiring self-test failed (hints above).")
        finish("flash")

    # 4. desk test
    if begin("desktest"):
        if cmd_desktest(_ns(args)) != 0:
            return bail("Desk test didn't pass.")
        finish("desktest")

    # 5. drop calibration
    if begin("drop"):
        h = 100.0
        if sys.stdin.isatty() and not args.fake:
            raw = input(">> Drop height you can measure accurately, in cm  [100] ").strip()
            if raw:
                try:
                    h = float(raw)
                except ValueError:
                    pass
        if cmd_drop(_ns(args, height_cm=h, drops=5, yes=True)) != 0:
            return bail("Calibration didn't complete.")
        if not args.fake:
            print("\n  Baking the calibration into the device...")
            if cmd_flash(_ns(args)) != 0:
                return bail("Re-flash with calibration failed.")
        st["calibrated"] = True
        finish("drop")

    print("\n" + "=" * 62)
    print("  🎉 WIZARD COMPLETE — the electronics are built, verified, and")
    print("  calibrated. What's left is physical (BUILD.md 'Day 3+'):")
    print("    1. capsule bucket-test (tissue trick)  2. GoPro mount, 24h cure")
    print("    3. ride  4. ./tools/jump sync   → report with his best jump")
    print("=" * 62)
    if LOG.path:
        print(f"  (full log of everything: {LOG.path})")
    return 0


# -------------------------------------------------------------------- report


def _tail(path: Path, max_bytes: int = 14000) -> str:
    try:
        data = path.read_text(errors="replace")
    except OSError as e:
        return f"(unreadable: {e})"
    if len(data) > max_bytes:
        return f"(...{len(data) - max_bytes} bytes trimmed...)\n" + data[-max_bytes:]
    return data


def cmd_report(args) -> int:
    """Collect everything needed to troubleshoot remotely into one file."""
    out_dir = DATA_DIR / "diagnostics"
    out_dir.mkdir(parents=True, exist_ok=True)
    path = out_dir / f"report-{datetime.now().strftime('%Y%m%d-%H%M%S')}.txt"
    S: list[str] = []

    def sec(title: str):
        S.append(f"\n{'=' * 60}\n== {title}\n{'=' * 60}")

    import platform as pf

    S.append("JUMP HEIGHT DIAGNOSTIC REPORT")
    S.append("Send this whole file to Claude (or attach to a GitHub issue).")
    S.append(f"generated: {datetime.now().isoformat()}")

    sec("system")
    S.append(f"platform : {pf.platform()}")
    if sys.platform == "darwin":
        S.append(f"macOS    : {pf.mac_ver()[0]}")
    S.append(f"python   : {sys.version.split()[0]} ({sys.executable})")
    pio = find_pio()
    if pio:
        try:
            v = subprocess.run([pio, "--version"], capture_output=True, text=True,
                               timeout=20).stdout.strip()
        except Exception as e:
            v = f"(error: {e})"
        S.append(f"pio      : {v} [{pio}]")
    else:
        S.append("pio      : NOT FOUND (run ./tools/jump setup)")
    try:
        import serial  # type: ignore
        S.append(f"pyserial : {getattr(serial, '__version__', '?')}")
    except ImportError:
        S.append("pyserial : not installed (POSIX fallback in use)")

    sec("repo")
    for c in (["git", "rev-parse", "--abbrev-ref", "HEAD"],
              ["git", "rev-parse", "--short", "HEAD"],
              ["git", "status", "--short"]):
        r = subprocess.run(c, capture_output=True, text=True, cwd=str(REPO))
        S.append(f"$ {' '.join(c)}\n{(r.stdout or r.stderr).strip()}")

    sec("config/params.json")
    try:
        S.append(CONFIG_PATH.read_text().strip())
    except OSError as e:
        S.append(f"(unreadable: {e})")

    sec("wizard progress")
    S.append(json.dumps(load_wizard_state(), indent=2))

    sec("serial ports visible")
    ports = scan_ports()
    S.append("\n".join(ports) if ports else "(none)")

    sec("live device")
    dev = proc = None
    try:
        dev, proc = open_device(args)
        S.append("connected: " + dev.sp.path)
        S.append("--- selftest ---")
        S.extend(dev.command("selftest", timeout=15))
        S.append("--- info ---")
        S.extend(dev.command("info", timeout=10))
        S.append("--- stats ---")
        S.extend(dev.command("stats", timeout=10))
    except (SystemExit, TimeoutError, OSError) as e:
        S.append(f"(no live device: {e})")
    finally:
        if dev:
            dev.close()
        if proc:
            proc.terminate()

    sec("recent logs")
    logs = []
    if (DATA_DIR / "logs").exists():
        logs = sorted((p for p in (DATA_DIR / "logs").glob("*.log") if p != LOG.path),
                      key=lambda p: p.stat().st_mtime)[-3:]
    if logs:
        for lp in logs:
            S.append(f"\n----- {lp.name} -----\n{_tail(lp)}")
    else:
        S.append("(no logs yet)")

    S.append("\n" + "=" * 60 + "\n== END REPORT\n" + "=" * 60)
    path.write_text("\n".join(S) + "\n")
    print(f"\n📋 Diagnostic report written to:\n   {path}\n")
    print("Send that file to Claude (paste it, or attach it) and it has "
          "everything:\nsystem, versions, config, wizard progress, ports, live "
          "self-test, recent logs.")
    return 0


